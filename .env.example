# Public Convex deployment URL, created by `pnpm convex dev`.
NEXT_PUBLIC_CONVEX_URL=

# Public event code. This identifies a room; it does not grant host permissions.
NEXT_PUBLIC_EVENT_CODE=WEST26

# Server-only staff credentials configured with `convex env set`.
# HOST_PIN unlocks Game Master controls. ROOM_PIN unlocks only breakout-room tools.
HOST_PIN=
ROOM_PIN=

# Optional direct Gartic room URL set shortly before the event.
NEXT_PUBLIC_GARTIC_URL=
